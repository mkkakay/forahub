    <script>
      const GTM_IDS = {
        nonprod: "GTM-T7LFTSK6",
        prod: "GTM-FVTRGQ",
      };
      const GTM_HOSTS = {
        nonprod: "https://gtmtest.icrc.org",
        prod: "https://www.googletagmanager.com",
      };
      const isProd = () => {
        const host = window.location.hostname.toLowerCase();
        return !host.includes("icrc10.lndo") && !host.startsWith("www2-");
      };
      const gtmId = isProd() ? GTM_IDS.prod : GTM_IDS.nonprod;
      const gtmHost = isProd() ? GTM_HOSTS.prod : GTM_HOSTS.nonprod;

      (function () {
        if (!gtmId) return;
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          "gtm.start": new Date().getTime(),
          event: "gtm.js",
        });
        var gtmScript = document.createElement("script");
        gtmScript.async = true;
        gtmScript.src = gtmHost + "/gtm.js?id=" + gtmId;
        document.head.appendChild(gtmScript);
      })();
    </script>
