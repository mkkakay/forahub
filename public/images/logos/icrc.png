    <script src="/core/assets/vendor/jquery/jquery.min.js?v=3.7.1"></script>
    <script>
      $(function () {
        const localesDir = "/sites/default/404-pages/locales";
        const supportedLanguages = [
          "en",
          "ar",
          "de",
          "es",
          "fr",
          "pt",
          "ru",
          "zh",
        ];
        const defaultLanguage = "en";
        let currentLanguage = defaultLanguage;

        function getBrowserLanguage() {
          if (navigator.languages && navigator.languages.length > 0) {
            return navigator.languages[0];
          } else if (navigator.language) {
            return navigator.language;
          } else {
            return "en";
          }
        }

        function getPrimaryLanguageCode(lang) {
          if (!lang) return "en";
          return lang.split("-")[0].toLowerCase();
        }

        function detectLanguage() {
          const pathSegments = window.location.pathname.split("/");
          if (
            pathSegments.length > 1 &&
            supportedLanguages.includes(pathSegments[1])
          ) {
            return pathSegments[1];
          }

          // If no supported language in URL, try browser
          const browserLang = getPrimaryLanguageCode(getBrowserLanguage());
          if (supportedLanguages.includes(browserLang)) {
            return browserLang;
          }

          // Fallback
          return defaultLanguage;
        }

        async function fetchTranslations(lang) {
          try {
            const data = await $.ajax({
              url: `${localesDir}/${lang}.json`,
              dataType: "json",
            });
            return data;
          } catch (jqXHR) {
            console.error(
              `Could not load translation file for ${lang}. Status: ${jqXHR.status}, TextStatus: ${jqXHR.statusText}`
            );
            if (lang !== defaultLanguage) {
              console.warn(
                `Falling back to default language (${defaultLanguage}) for translations.`
              );
              return fetchTranslations(defaultLanguage);
            }
            return null;
          }
        }

        function applyTranslations(translations) {
          if (!translations) return;

          $("[data-translate-key]").each(function () {
            const key = $(this).attr("data-translate-key");
            if (translations[key]) {
              $(this).text(translations[key]);
            }
          });

          $("[data-translate-attr-alt]").each(function () {
            const key = $(this).attr("data-translate-attr-alt");
            if (translations[key]) {
              $(this).attr("alt", translations[key]);
            }
          });

          $("[data-translate-attr-title]").each(function () {
            const key = $(this).attr("data-translate-attr-title");
            if (translations[key]) {
              $(this).attr("title", translations[key]);
            }
          });

          $("[data-translate-attr-src]").each(function () {
            const key = $(this).attr("data-translate-attr-src");
            if (translations[key]) {
              $(this).attr("src", translations[key]);
            }
          });

          $("[data-translate-link]").each(function () {
            const key = $(this).attr("data-translate-link");
            if (translations[key]) {
              let newHref = translations[key];
              if (
                !newHref.startsWith("http") &&
                !newHref.startsWith("https") &&
                !newHref.startsWith("/" + currentLanguage + "/")
              ) {
                if (newHref.startsWith("/")) {
                  newHref = "/" + currentLanguage + newHref;
                } else {
                  newHref = "/" + currentLanguage + "/" + newHref;
                }
              }
              $(this).attr("href", newHref);
            }
          });

          if (translations.htmlDir) {
            $("html").attr("dir", translations.htmlDir);
          } else {
            $("html").attr("dir", "ltr"); // Default
          }
          if (translations.htmlLang) {
            $("html").attr("lang", translations.htmlLang);
          }

          const $usercentricsScript = $("#usercentrics-cmp");
          if ($usercentricsScript.length && translations.htmlLang) {
            $usercentricsScript.attr("data-language", translations.htmlLang);
          }

          if (translations.canonicalUrl) {
            const $canonicalLink = $('link[rel="canonical"]');
            if ($canonicalLink.length) {
              $canonicalLink.attr("href", translations.canonicalUrl);
            }
          }
          if (translations.shortlinkUrl) {
            const $shortlinkLink = $('link[rel="shortlink"]');
            if ($shortlinkLink.length) {
              $shortlinkLink.attr("href", translations.shortlinkUrl);
            }
          }

          if (translations.bodyGaSlug) {
            document.body.setAttribute("data-ga-slug", translations.bodyGaSlug);
          }

          const socialPlatforms = [
            {
              slug: "instagram",
              titleKey: "socialInstagramTitle",
              linkKey: "socialInstagramLink",
            },
            {
              slug: "facebook",
              titleKey: "socialFacebookTitle",
              linkKey: "socialFacebookLink",
            },
            { slug: "x", titleKey: "socialXTitle", linkKey: "socialXLink" },
            {
              slug: "youtube",
              titleKey: "socialYoutubeTitle",
              linkKey: "socialYoutubeLink",
            },
            {
              slug: "tiktok",
              titleKey: "socialTiktokTitle",
              linkKey: "socialTiktokLink",
            },
            {
              slug: "linkedin",
              titleKey: "socialLinkedinTitle",
              linkKey: "socialLinkedinLink",
            },
            {
              slug: "telegram",
              titleKey: "socialTelegramTitle",
              linkKey: "socialTelegramLink",
            },
            {
              slug: "vkontakte",
              titleKey: "socialVkontakteTitle",
              linkKey: "socialVkontakteLink",
            },
            {
              slug: "wechat",
              titleKey: "socialWechatTitle",
              linkKey: "socialWechatLink",
            },
            {
              slug: "weibo",
              titleKey: "socialWeiboTitle",
              linkKey: "socialWeiboLink",
            },
            {
              slug: "youku",
              titleKey: "socialYoukuTitle",
              linkKey: "socialYoukuLink",
            },
          ];

          const $socialListContainer = $("ul[data-social-list-lang-class]");
          if ($socialListContainer.length) {
            const $liElementsMap = new Map();
            $socialListContainer.find("li").each(function () {
              const $aTag = $(this).find("a[data-ga-slug]");
              if ($aTag.length) {
                const slug = $aTag.attr("data-ga-slug");
                $liElementsMap.set(slug, $(this).detach());
              }
            });

            const slugsToDisplayInOrder =
              translations.socialPlatformOrder ||
              socialPlatforms.map((p) => p.slug);

            slugsToDisplayInOrder.forEach((slug) => {
              const platformConfig = socialPlatforms.find(
                (p) => p.slug === slug
              );
              const $liElement = $liElementsMap.get(slug);

              if (platformConfig && $liElement) {
                const linkKey = platformConfig.linkKey;
                const titleKey = platformConfig.titleKey;
                const $linkElement = $liElement.find("a");

                if (
                  translations[linkKey] &&
                  translations[linkKey].trim() !== ""
                ) {
                  $linkElement.attr("href", translations[linkKey]);
                  if (translations[titleKey]) {
                    $linkElement.attr("title", translations[titleKey]);
                  } else {
                    $linkElement.attr("title", platformConfig.slug);
                  }
                  $liElement.show();
                  $socialListContainer.append($liElement);
                } else {
                  $liElement.hide();
                }
              }
            });
          }

          const $socialListElement = $("[data-social-list-lang-class]");
          if ($socialListElement.length) {
            if (translations.socialMenuLangSuffix) {
              $socialListElement.attr(
                "class",
                "social-list social_" +
                  translations.socialMenuLangSuffix +
                  "-menu"
              );
            } else {
              $socialListElement.attr("class", "social-list");
            }
          }
        }

        async function init() {
          currentLanguage = detectLanguage();

          const translations = await fetchTranslations(currentLanguage);
          if (translations) {
            applyTranslations(translations);
          } else {
            console.warn(
              "No translations applied. Displaying default content."
            );
          }
        }

        init();
      });
    </script>
  </body>
</html>
