                <div class="split-quote-image__top container">
                    <div class="split-quote-image__image">
                        <div class="split-quote-image__inner">
                            <img alt="Sahitha Sagir" sizes="&#40;min-width: 781px&#41; 585px, 1px" srcset="/-/media/gfo/3about/5careers/sahitha-sagir-1.jpg?rev=228c1d3834a64972a1bb00dce7145577&w=1429&hash=47D8EA845BE722F2E0E3E5E2F025717C 1429w, /-/media/gfo/3about/5careers/sahitha-sagir-1.jpg?rev=228c1d3834a64972a1bb00dce7145577&w=1200&hash=8915110AB7DF1E543AFFD17A2D767166 1200w, /-/media/gfo/3about/5careers/sahitha-sagir-1.jpg?rev=228c1d3834a64972a1bb00dce7145577&w=800&hash=987E5F286A04F0A9F6A4B2AAC4BA4BA4 800w, /-/media/gfo/3about/5careers/sahitha-sagir-1.jpg?rev=228c1d3834a64972a1bb00dce7145577&w=400&hash=736EDF3EE5F8EE0F087E5FA315342DD1 400w, /-/media/gfo/3about/5careers/sahitha-sagir-1.jpg?rev=228c1d3834a64972a1bb00dce7145577&w=1&hash=F2A3972E4EF08AA63160848C3C82E9F3 1w" height="2000" width="1429" loading="lazy" class="image-element" style="--image-height:2000; --image-width:1429">
                        </div>
                    </div>
                    <div class="split-quote-image__quote">
                        <div class="split-quote-image__inner">
                            	<section style="--c-pull-quote-bg:#313A44" class="pull-quote component  pull-quote--has-background pull-quote--dark theme-dark ">
		<div class="pull-quote__inner">
			<div class="pull-quote__container">
				<figure class="pull-quote__figure">
										<blockquote id="25c45d6169004130815e33ed2b6434b2" class="pull-quote__blockquote txt-pull-quote">
						<h4>“What I love most about my role at the Gates Foundation is the incredible diversity of our portfolio and the opportunities this creates for me to learn something new every day!”</h4>
					</blockquote>
					<figcaption class="pull-quote__caption">
							<div class="pull-quote__author">- <span style="color:white;">Sahitha Sagir</span></div>
													<div class="pull-quote__source">
								Senior Strategy Officer
							</div>
													<div class="pull-quote__employer">
								Global Development (Delhi office)
							</div>
					</figcaption>
				</figure>
				<div class="pull-quote__share-container">
					


				</div>
			</div>
		</div>
	</section>

                        </div>
                    </div>
                </div>
                <div class="split-quote-image__caption">
