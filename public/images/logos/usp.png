					<div class="elementor-posts-container elementor-posts elementor-posts--skin-classic elementor-grid">
				<article class="elementor-post elementor-grid-item post-45012 post type-post status-publish format-standard has-post-thumbnail hentry category-objetos-categorias category-sti-superintendencia-de-tecnologia-da-informacao category-tecnologia-categorias tag-acervo-tecnologico tag-servico-de-tecnologia-da-informacao tag-sti entry has-media">
				<a class="elementor-post__thumbnail__link" href="https://imagens.usp.br/editorias/objetos-categorias/acerso-tecnologico-sti/" >
			<div class="elementor-post__thumbnail"><img decoding="async" width="1620" height="1080" src="https://imagens.usp.br/wp-content/uploads/Acervo-Tecnologico-STI_Foto-Marcos-Santos_MG_9986-77-1620x1080.jpg" class="attachment-medium size-medium wp-image-45022" alt="" loading="lazy" srcset="https://imagens.usp.br/wp-content/uploads/Acervo-Tecnologico-STI_Foto-Marcos-Santos_MG_9986-77-1620x1080.jpg 1620w, https://imagens.usp.br/wp-content/uploads/Acervo-Tecnologico-STI_Foto-Marcos-Santos_MG_9986-77-1728x1152.jpg 1728w, https://imagens.usp.br/wp-content/uploads/Acervo-Tecnologico-STI_Foto-Marcos-Santos_MG_9986-77-768x512.jpg 768w, https://imagens.usp.br/wp-content/uploads/Acervo-Tecnologico-STI_Foto-Marcos-Santos_MG_9986-77-1536x1024.jpg 1536w, https://imagens.usp.br/wp-content/uploads/Acervo-Tecnologico-STI_Foto-Marcos-Santos_MG_9986-77-2048x1365.jpg 2048w" sizes="(max-width: 1620px) 100vw, 1620px" /></div>
		</a>
