# ForaHub environment variables — copy to .env.local and fill in real
# values. NEVER commit .env.local. Real values for production live in
# Vercel's Environment Variables UI; mirror them here for local dev.

# ─── Supabase ────────────────────────────────────────────────────────
# Public Supabase URL — exposed to the browser via NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
# Public anon key — RLS-protected reads only. Safe to ship to clients.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service-role key — full DB access, server-only. NEVER expose to the
# client. Only imported by src/lib/supabase/admin.ts and used in API
# routes / server components.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── App ─────────────────────────────────────────────────────────────
# Public canonical URL of the deployment. Used for OG links, OAuth
# redirects, and email CTAs. Set per-env (Production / Preview / Dev).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Shared secrets ──────────────────────────────────────────────────
# Bearer for /api/scrape, /api/admin/**, /api/import-*, etc. Required
# in prod. Sent via the `x-admin-key` header. Rotate after any repo or
# team-access change.
ADMIN_SECRET=replace-with-a-long-random-string
# Vercel cron auth — Vercel sends Authorization: Bearer ${CRON_SECRET}
# to scheduled functions. Required for /api/cron/* to run on schedule.
CRON_SECRET=replace-with-a-long-random-string

# ─── Email (Resend) ──────────────────────────────────────────────────
# Resend API key for transactional email (welcome, org invite, claim
# denial). Without this, the routes silently no-op the send.
RESEND_API_KEY=re_replace_with_real_key

# ─── Stripe ──────────────────────────────────────────────────────────
# Server-side Stripe secret. Required for /api/stripe/checkout.
STRIPE_SECRET_KEY=sk_test_replace
# Webhook signing secret — verified in /api/stripe/webhook against the
# Stripe-Signature header. Set the matching value in Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=whsec_replace
# Price IDs the checkout flow uses.
STRIPE_PRO_PRICE_ID=price_replace_pro
STRIPE_FOUNDING_PRICE_ID=price_replace_founding

# ─── AI (Anthropic) ──────────────────────────────────────────────────
# Claude API key — powers the scraper, the admin classification +
# location-inference jobs, and the AI widget. Capped at ~$5/month per
# CLAUDE.md.
ANTHROPIC_API_KEY=sk-ant-replace

# ─── Images & media ──────────────────────────────────────────────────
# Pexels — hero slide imagery + event banner backfill.
PEXELS_API_KEY=replace-pexels-key
# Unsplash — secondary banner fallback when Pexels misses.
UNSPLASH_ACCESS_KEY=replace-unsplash-key
# Brandfetch — official org logo lookup. Server-side only.
BRANDFETCH_API_KEY=replace-brandfetch-key

# ─── Geo ─────────────────────────────────────────────────────────────
# LocationIQ — 2 req/sec free tier for /api/admin/geocode-events. When
# missing, the route falls back to Nominatim (1 req/sec, slower).
LOCATIONIQ_API_KEY=replace-locationiq-key
# Stadia Maps key — public, exposed to client for the map tile loader.
NEXT_PUBLIC_STADIA_API_KEY=replace-stadia-key
